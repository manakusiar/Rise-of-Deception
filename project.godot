; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Rise of Deception"
config/tags=PackedStringArray("platformer")
run/main_scene="uid://bekk1rqcd3nk7"
config/features=PackedStringArray("4.7", "Forward Plus")

[autoload]

Utils="*uid://df2ve3gmi2inv"
SignalBus="*uid://d0aw5pg2lgidf"
AllItems="*uid://f7sdsw2m65lb"
DataManager="*uid://stb8ql0aji14"
Global="*uid://gv6u6pry8pvd"
CameraManager="*uid://bifkpwps2at1k"
DevConsole="*uid://ccoijpiv8l45j"

[debug]

gdscript/warnings/unused_parameter=0
gdscript/warnings/unused_signal=0

[dev_console]

configuration/title_label="CONSOLE"
configuration/use_default_commands=true
configuration/view_default_commands=true
configuration/use_command_history=true
configuration/background_transparency=0.9
configuration/keep_size_after_closing=false
configuration/keep_position_after_closing=false
configuration/keep_topmost=true
configuration/debug_only=true

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/dev-console/plugin.cfg", "res://addons/kanban_tasks/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://assets/": "gray",
"res://components/": "green",
"res://src/autoloads/": "purple"
}

[global_group]

Saveable="A node whose data can be saved"
Player=""
passage=""

